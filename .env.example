# Copy this file to `.env` for a zero-credential local mock server. This profile
# exercises the real run/session HTTP + SSE lifecycle, but does not call an LLM
# or start the MotionDoc MCP.
NODE_ENV=development

# Keep the API off Next.js's usual port 3000. If you also run this repository's
# Vite UI, its proxy reads the same API port and Vite uses 5173 by default.
PORT=3010
DATA_DIR=./data
LOG_LEVEL=info
SHUTDOWN_GRACE_MS=30000

# Development-only wildcard so a SlideX editor on any localhost port can call
# the API. Production startup rejects `*` when the agent is enabled; replace it
# with exact deployed editor origins there.
CORS_ORIGIN=*

# Runnable mock profile: register the reconnectable API and bypass Supabase
# with one fixed development user. DEV_AUTH_BYPASS is ignored in production.
AGENT_DRIVER=mock
SLIDEX_AGENT_ENABLED=true
# The mock ignores this value. `gpt-5.4` is also the verified default for the
# development OAuth path described below.
DEFAULT_MODEL=gpt-5.4
DEV_AUTH_BYPASS=1
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.com

# Matching SlideX editor `.env.local` values (these belong in the editor repo,
# not in this server's `.env`):
# NEXT_PUBLIC_SLIDEX_AGENT_ENABLED=true
# NEXT_PUBLIC_SLIDEX_AGENT_SERVER_URL=http://localhost:3010
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ---------------------------------------------------------------------------
# Real Heddle mode — replace AGENT_DRIVER above with `heddle`, then configure
# the MotionDoc MCP and one supported development/production auth path.
# ---------------------------------------------------------------------------

# Heddle workspace and SlideX MotionDoc MCP. This example runs the editor
# repository's existing `npm run mcp` script; use absolute paths so a service
# process does not depend on the shell's current directory.
# HEDDLE_WORKSPACE_ROOT=/absolute/path/to/SlideX
# MOTIONDOC_MCP_COMMAND=npm
# MOTIONDOC_MCP_ARGS='["run","mcp"]'
# MOTIONDOC_MCP_CWD=/absolute/path/to/SlideX

# Development option: use an existing Heddle OAuth credential store instead of
# the per-request llmApiKey. Ignored in production.
# DEV_HEDDLE_AUTH_STORE=/absolute/path/to/heddle/auth.json

# Supabase option: required when DEV_AUTH_BYPASS is off. The VITE_* pair is
# needed only by this repository's bundled Vite demo; the SlideX editor injects
# its own bearer-token provider. Enable anonymous sign-ins in this Supabase
# project's Auth settings for the editor's no-login MVP identity flow.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Production checklist (replace the active development values above):
# NODE_ENV=production
# CORS_ORIGIN=https://YOUR_SLIDEX_EDITOR_ORIGIN
# AGENT_DRIVER=heddle
# SLIDEX_AGENT_ENABLED=true
# Remove DEV_AUTH_BYPASS and configure Supabase plus the MotionDoc MCP.
# Users provide their OpenAI API key in the editor for each browser tab. Do not
# add a shared model key or model-key persistence to this server environment.

NODE_ENV=development
PORT=3000

# Supabase Auth. The frontend uses the VITE_* values, the backend uses the
# non-VITE values to verify Bearer tokens with Supabase Auth.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Railway will inject RAILWAY_VOLUME_MOUNT_PATH when a volume is attached.
# DATA_DIR wins if explicitly set. Recommended Railway value: /data.
DATA_DIR=./data

# CORS origin for local Vite or a separate SlideX frontend.
CORS_ORIGIN=http://localhost:5173

# Use mock until Jay's module is available. Set to heddle in production.
AGENT_DRIVER=mock
DEFAULT_MODEL=gpt-4.1
HEDDLE_WORKSPACE_ROOT=

# Jay's compiled JS module should export runSlideXAgent(args) or default(args).
# Example: ./dist/server/agent/jayAgent.js
JAY_AGENT_MODULE_PATH=

# MotionDoc MCP stdio subprocess config. Args may be JSON array or shell-like text.
MOTIONDOC_MCP_COMMAND=
MOTIONDOC_MCP_ARGS=
MOTIONDOC_MCP_CWD=

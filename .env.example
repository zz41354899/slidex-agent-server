NODE_ENV=development
# API server port. The Vite dev proxy reads the same PORT, so `PORT=3010 npm run
# dev` moves both together. Vite auto-picks its own web port if 5173 is busy.
PORT=3000

# Supabase Auth. The frontend uses the VITE_* values, the backend uses the
# non-VITE values to verify Bearer tokens with Supabase Auth.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Railway will inject RAILWAY_VOLUME_MOUNT_PATH when a volume is attached.
# DATA_DIR wins if explicitly set. Recommended Railway value: /data.
DATA_DIR=./data

# CORS origin for local Vite or a separate SlideX frontend.
CORS_ORIGIN=http://localhost:5173

# Use mock for local UI work (no LLM). Set to heddle to run the real agent.
AGENT_DRIVER=mock
DEFAULT_MODEL=gpt-4.1
HEDDLE_WORKSPACE_ROOT=

# Dev-only: skip Supabase auth and treat every request as DEV_USER_ID. Lets you
# test the API/UI without Supabase. IGNORED in production (NODE_ENV=production).
DEV_AUTH_BYPASS=
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.com

# Dev-only: use Heddle OAuth credentials (e.g. a Codex subscription) instead of
# the per-request llmApiKey. Run `npx heddle auth login openai` in this repo,
# check the store path with `npx heddle auth status`, and point this at that
# auth.json. Use an OAuth-allowlisted model (gpt-5.4, gpt-5.2-codex, ...).
# IGNORED in production.
DEV_HEDDLE_AUTH_STORE=

# SlideX MotionDoc MCP command. The Heddle driver prepares it once as a
# self-contained host extension and reuses it across requests. Heddle spawns the
# MCP per tool call, so this is the command Heddle runs (not a long-lived
# process). Args may be a JSON array or shell-like text.
MOTIONDOC_MCP_COMMAND=
MOTIONDOC_MCP_ARGS=
MOTIONDOC_MCP_CWD=
